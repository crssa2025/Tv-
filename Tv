<!doctype html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>بث مباشر | عبود #هاشتاج_شاهد</title>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/dplayer/dist/DPlayer.min.css">
    <script src="https://cdn.jsdelivr.net/npm/hls.js@latest"></script>
    <script src="https://cdn.jsdelivr.net/npm/dplayer/dist/DPlayer.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@600;900&display=swap" rel="stylesheet">

    <style>
        body, html {
            margin: 0; padding: 0; width: 100%; height: 100%;
            background: radial-gradient(circle, #1a1a1a 0%, #000000 100%);
            font-family: 'Cairo', sans-serif;
            color: white; overflow: hidden;
            display: flex; flex-direction: column; align-items: center; justify-content: center;
        }

        /* حاوية العنوان والحقوق */
        .branding {
            text-align: center; margin-bottom: 20px; z-index: 10;
        }

        .branding h1 {
            font-size: 28px; font-weight: 900; margin: 0;
            background: linear-gradient(to right, #00bfff, #ffffff);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            drop-shadow: 0 2px 10px rgba(0, 191, 255, 0.5);
        }

        .branding p {
            font-size: 18px; margin: 5px 0; color: #ff0000;
            font-weight: bold; animation: pulse 1.5s infinite;
        }

        /* حاوية المشغل في المنتصف */
        .player-wrapper {
            width: 90%; max-width: 900px;
            aspect-ratio: 16 / 9;
            background: #000;
            border: 3px solid #333;
            border-radius: 15px;
            overflow: hidden;
            box-shadow: 0 0 50px rgba(0, 191, 255, 0.3);
            position: relative;
        }

        #dplayer { width: 100%; height: 100%; }

        /* حقوق ثابتة داخل الواجهة */
        .footer-rights {
            margin-top: 20px; font-size: 16px; font-weight: 600;
            color: rgba(255, 255, 255, 0.6);
        }

        .footer-rights span { color: #00bfff; }

        @keyframes pulse {
            0% { opacity: 1; }
            50% { opacity: 0.5; }
            100% { opacity: 1; }
        }

        /* لضمان تناسب الشاشات الصغيرة */
        @media (max-width: 768px) {
            .branding h1 { font-size: 22px; }
            .player-wrapper { width: 95%; }
        }
    </style>
</head>
<body>

    <div class="branding">
        <h1>ريال مدريد 🆚 مانشستر سيتي</h1>
        <p>🔴 بث مباشر HD</p>
    </div>

    <div class="player-wrapper">
        <div id="dplayer"></div>
    </div>

    <div class="footer-rights">
        بواسطة: <span>عبود #هاشتاج_شاهد</span>
    </div>

    <script>
        const streamUrl = 'http://wjk30.tutor3.site/live/51838_.m3u8?session=fgXV65Um2lfy1XM-PnwCNI6JKBGv-7c8uR6nyqvK0yPD6645oYewQjFQ6kFRCCFO8v9weMjgiE5rg7pCM4ODC3gY8vmYU53y&location=local';

        const dp = new DPlayer({
            container: document.getElementById('dplayer'),
            live: true,
            autoplay: true,
            theme: '#00bfff',
            lang: 'ar',
            logo: 'https://cdn-icons-png.flaticon.com/512/5219/5219313.png', // أيقونة صغيرة اختيارية
            video: {
                url: streamUrl,
                type: 'hls'
            }
        });

        // محاولة التشغيل التلقائي
        dp.on('canplay', function () {
            dp.play();
        });

        // رسالة تنبيه إذا حظر المتصفح الصوت
        console.log("Welcome to Abood's Live Stream");
    </script>

</body>
</html>
